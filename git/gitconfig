[color]
	ui = auto

[core]
	excludesfile = $HOME/.gitignore

[filter "lfs"]
	# https://mydeveloperplanet.com/2018/10/31/git-lfs-why-and-how-to-use/
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process

[init]
	defaultBranch = main

